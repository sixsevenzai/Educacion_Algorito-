Algoritmo Estructura_Simple
	//Comparar el menor de dos numeros reales 
	Definir numero1, numero2 Como real;
	Escribir"Ingresar el primero numero: ";
	Leer numero1;
	Escribir "Ingresar el segundo numero: ";
	leer numero2; 
	//Determinar el menor.
	Si numero1 < numero2 Entonces 
		Escribir "El menor es: ", numero1; 
	FinSi
	Si numero2 < numero1 Entonces 
		Escribir "El menor es:" , numero2;
	FinSi
FinAlgoritmo
