Algoritmo Selectiva_Doble
	//Determinar si un numero es PAR o IMPAR
	Definir numero1 Como Entero;
	Escribir "Ingresar un numero: ";
	Leer numero1; 
	//SELECTIVA DOBLE 
	Si numero1 MOD 2 = 0 Entonces
		Escribir "Es un numero PAR ", numero1; 
	SiNo
		Escribir "Es un numero IMPAR: ", numero1; 
	FinSi
FinAlgoritmo
